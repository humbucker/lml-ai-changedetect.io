# Changedetection Data Configuration Whitelist
# 1. Ignore everything in changedetection-data
changedetection-data/**/*

# 2. Allow directory traversal
!changedetection-data/**/

# 3. Whitelist specific configuration files
!changedetection-data/changedetection.json
!changedetection-data/secret.txt
!changedetection-data/**/watch.json
